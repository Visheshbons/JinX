// Boot entry point

#include <stdio.jc>

u32 boot() {
    // MEMORY
    ptr stack = 0x7C00;
    ptr heap = 0x10000;
    ptr screen = 0xB8000;

    // Hardware link
    u32 port_pic1 = 0x20;
    u32 port_pic2 = 0xA0;
    u32 port_kb = 0x60;

    // Multiboot magic number for grub
    u32 magoc = 0x1BADB002;

    // Boot status
    u32 status = k_main();

    while (true) {}

    return status;
}
